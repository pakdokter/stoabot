# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://stoabot:password@db:5432/stoabot
DATABASE_URL_SYNC=postgresql://stoabot:password@db:5432/stoabot

# Redis (rate limiting & session)
REDIS_URL=redis://redis:6379/0

# OCR — pilih salah satu: "google" atau "tesseract"
OCR_PROVIDER=tesseract
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-vision.json

# Business info (untuk PDF statement)
BUSINESS_NAME=Stoa Space
BUSINESS_ADDRESS=Jl. Pattimura 107, Selong, Lombok
BUSINESS_PHONE=+62 xxx-xxxx-xxxx

# App
DEBUG=false
LOG_LEVEL=INFO
TIMEZONE=Asia/Makassar
